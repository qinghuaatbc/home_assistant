# Home Assistant (NestJS) — Environment Configuration
# Copy this file to .env and fill in your values.
# These override the defaults in config/configuration.yaml.

# ── Home ──────────────────────────────────────────────────────────────────────
HA_NAME=My Home
HA_LATITUDE=39.9042
HA_LONGITUDE=116.4074
HA_ELEVATION=43
HA_UNIT_SYSTEM=metric
HA_TIME_ZONE=Asia/Shanghai
HA_COUNTRY=CN
HA_CURRENCY=CNY

# ── HTTP ──────────────────────────────────────────────────────────────────────
HA_HTTP_PORT=8123

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
HA_JWT_SECRET=change-this-secret-in-production-at-least-32-chars
HA_JWT_EXPIRY=24h

# ── Database ──────────────────────────────────────────────────────────────────
HA_DB_TYPE=better-sqlite3
HA_DB_PATH=ha.db

# ── MQTT ──────────────────────────────────────────────────────────────────────
# HA_MQTT_BROKER=broker.hivemq.com

# ── AI Voice ──────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# Used for transcribing voice commands (Whisper API). Only needed if using voice input.
OPENAI_API_KEY=

# ── Cameras ───────────────────────────────────────────────────────────────────
# RTSP URLs for each camera stream. Env var naming:
#   HA_CAMERA_{NAME}_{LABEL}_URL
# where NAME = camera name uppercased, non-alphanum → underscore
# Example:
# HA_CAMERA_DRIVEWAY_SD_URL=rtsp://user:pass@host:554/stream1
# HA_CAMERA_DRIVEWAY_HD_URL=rtsp://user:pass@host:554/stream0
